# Required
JWT_SECRET=change-me-to-a-long-random-string

# Database & uploads (defaults work for local dev; set for Docker)
DATABASE_PATH=./launchpad.db
UPLOADS_DIR=./uploads
PORT=3001

# Set to "production" in Docker/Coolify to enable strict security warnings
NODE_ENV=development

# LLM Provider: "anthropic" or "ollama" (default: ollama)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-haiku-4-5-20251001    # default for anthropic
# LLM_BASE_URL=https://api.anthropic.com  # default for anthropic

# Voice transcription (optional — requires whisper.cpp + ffmpeg installed)
# WHISPER_MODEL_PATH=/path/to/ggml-base.en.bin

# GitHub Integration (optional — personal access token with repo:read)
# GITHUB_PAT=ghp_your_token_here

# Your login email (used by Telegram bot + cron to find your account)
LAUNCHPAD_USER_EMAIL=your@email.com

# Telegram Bot (optional — create via @BotFather, get chat ID via @userinfobot)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your_chat_id
# TELEGRAM_BRIEF_HOUR=9   # hour in 24h local server time to send morning briefing (default: 9)

# MCP connector (leave blank to disable). Generate with: openssl rand -hex 32
MCP_API_KEY=
