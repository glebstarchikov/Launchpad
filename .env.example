JWT_SECRET=change-me-to-a-long-random-string
DATABASE_PATH=./launchpad.db
UPLOADS_DIR=./uploads
PORT=3001

# LLM Provider: "anthropic" or "ollama" (default)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-haiku-4-5-20251001    # default for anthropic
# LLM_BASE_URL=https://api.anthropic.com  # default for anthropic

# Voice transcription (optional — requires whisper.cpp + ffmpeg installed)
# WHISPER_MODEL_PATH=/path/to/ggml-base.en.bin

# GitHub Integration (optional — personal access token)
# GITHUB_PAT=ghp_your_token_here

# Your login email (used by Telegram bot + cron to identify your account)
LAUNCHPAD_USER_EMAIL=your@email.com

# Telegram Bot (optional — create via @BotFather)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your_chat_id

UPTIMEROBOT_API_KEY=    # optional; enables dashboard site-down action items
